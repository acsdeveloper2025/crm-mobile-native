<?xml version="1.0" encoding="utf-8"?>
<!--
  Network Security Configuration for CRM Mobile Native (Phase E1 follow-up).

  Policy:
    - Cleartext (HTTP) globally blocked.
    - Localhost + emulator loopback (10.0.2.2) allowed cleartext for
      Metro bundler + local backend during development only.
    - Production API domain uses strict TLS AND certificate pinning
      via <pin-set>. The pin set below MUST be populated with real
      SPKI SHA-256 fingerprints before a production build ships —
      see docs/ssl-pinning.md for the exact openssl command and
      rollout procedure.

  Rollout invariant: always keep AT LEAST TWO pins in the set at any
  time — the current leaf cert's key plus a backup. When rotating,
  publish the next cert's pin as the backup in a new app release,
  wait for adoption, then switch. This prevents a rotated cert from
  bricking the app between releases.
-->
<network-security-config>
    <!-- Block cleartext traffic globally -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>

    <!-- Allow cleartext for localhost only (React Native Metro bundler in dev) -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">localhost</domain>
        <domain includeSubdomains="false">10.0.2.2</domain>
    </domain-config>

    <!--
      Production API domain — certificate pinning ACTIVE (2026-04-19).

      Pin set:
        Primary: SPKI SHA-256 of the current leaf cert for
                 crm.allcheckservices.com (Let's Encrypt leaf, rotates every
                 ~60 days — refresh this pin when a new cert is issued).
        Backup : SPKI SHA-256 of the Let's Encrypt R13 intermediate CA.
                 Acts as a rotation safety net: Android matches any cert in
                 the presented chain against the pin set, so even when the
                 leaf rotates the intermediate keeps the app reachable until
                 the next app release ships an updated leaf pin.

      Expiration: 2026-12-31 — both pins MUST be reviewed and re-validated
      before this date. Pin rotation procedure documented in
      docs/ssl-pinning.md.

      Verified against live server on 2026-04-19 using the curl
      pinnedpubkey flag with sha256//+D94EBRU5pr3Lcn2SvqWT8E... returned
      HTTP 200 from https://crm.allcheckservices.com/ .

      Release pipeline guard: scripts/check-ssl-pins.sh fails the build if
      the pin-set element is missing, placeholder values leak through, or
      pin values are not 44-char base64 SHA-256 digests.
    -->
    <domain-config cleartextTrafficPermitted="false">
        <domain includeSubdomains="true">crm.allcheckservices.com</domain>
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
        <pin-set expiration="2026-12-31">
            <!-- Primary: crm.allcheckservices.com leaf cert (Let's Encrypt) -->
            <pin digest="SHA-256">+D94EBRU5pr3Lcn2SvqWT8E+MSR6oDpQx952sp+iH2M=</pin>
            <!-- Backup: Let's Encrypt R13 intermediate CA -->
            <pin digest="SHA-256">AlSQhgtJirc8ahLyekmtX+Iw+v46yPYRLJt9Cq1GlB0=</pin>
        </pin-set>
    </domain-config>
</network-security-config>
